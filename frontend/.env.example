# DocMatrix Frontend Environment Variables
# Copy this file to .env.local for local overrides.

# API base URL
# - Leave empty in hosted setups when frontend and backend share origin.
# - Set to http://localhost:8000 for local split-host development.
VITE_API_URL=http://localhost:8000

# Optional UI/feature flags
VITE_ENABLE_DEBUG=false
VITE_LEGACY_MODE=false
VITE_DEMO_MODE=false

# MEGA pipeline latency/retry tuning
# Retry count for transient failures (network/timeout/5xx/429)
VITE_MEGA_RETRY_COUNT=1
# Base delay (ms) for exponential backoff
VITE_MEGA_RETRY_BASE_MS=250

# Per-operation timeouts (ms)
VITE_MEGA_TIMEOUT_STATUS_MS=15000
VITE_MEGA_TIMEOUT_LIST_MS=25000
VITE_MEGA_TIMEOUT_CONNECT_MS=60000
VITE_MEGA_TIMEOUT_UPLOAD_MS=120000
VITE_MEGA_TIMEOUT_DOWNLOAD_MS=120000
VITE_MEGA_TIMEOUT_DISCONNECT_MS=20000
VITE_MEGA_TIMEOUT_DELETE_MS=20000
